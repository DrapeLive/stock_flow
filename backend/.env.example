DEBUG=False
SECRET_KEY=
ALLOWED_HOSTS=api.yourdomain.tld
CORS_ALLOWED_ORIGINS=https://stockflow-sigma.vercel.app

DB_NAME=stockflow
DB_USER=stockflow
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# Mirror of DB_* — consumed by the postgres container
